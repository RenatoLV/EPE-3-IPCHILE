# Variables de entorno - App Móvil Expo
# ¡NUNCA subir este archivo a Git!

# Firebase Web SDK - Obtén estos valores en Firebase Console > Configuración del proyecto > Web App
EXPO_PUBLIC_FIREBASE_API_KEY=TU_API_KEY_AQUI
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=appmovil-api-cloud.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://appmovil-api-cloud-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=appmovil-api-cloud
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=appmovil-api-cloud.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1006948232711
EXPO_PUBLIC_FIREBASE_APP_ID=TU_APP_ID_AQUI

# URL del backend REST (cambia a tu IP local o dominio en producción)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api
